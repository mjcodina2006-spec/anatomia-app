
{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "functions": {
    "api/claude.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/api/claude", "destination": "/api/claude" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}